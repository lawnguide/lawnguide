---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleCard from '@components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="All Articles | The Lawn Guide"
  description="Every article on The Lawn Guide, sorted by most recent."
>
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-12">
    <p class="text-xs uppercase tracking-widest text-terracotta-600 font-medium mb-5">Archive</p>
    <h1 class="font-serif text-4xl md:text-6xl text-forest-900 leading-tight tracking-tight">
      All articles
    </h1>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-24">
    {articles.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-12">
        {articles.map(article => <ArticleCard article={article} />)}
      </div>
    ) : (
      <p class="text-ink-500 italic font-serif">No articles yet.</p>
    )}
  </section>
</BaseLayout>