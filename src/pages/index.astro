---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleCard from '@components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [featured, ...rest] = articles;
---

<BaseLayout
  title="The Lawn Guide — Honest Lawn Care Advice for British Gardens"
  description="Practical, tested advice on UK lawn care, renovation, and the kit that actually works. From a real gardener with a real lawn."
>
  <section class="max-w-4xl mx-auto px-6 pt-16 md:pt-24 pb-16 text-center">
    <p class="text-xs uppercase tracking-widest text-terracotta-600 font-medium mb-6">
      Est. 2026 · UK
    </p>
    <h1 class="font-serif text-5xl md:text-7xl text-forest-900 leading-[1.05] mb-8 tracking-tight">
      The lawn guide for people who actually <em class="italic">use</em> their garden.
    </h1>
    <p class="text-xl text-ink-500 leading-relaxed max-w-2xl mx-auto font-serif">
      Honest reviews. Real-world testing. Month-by-month guides written for British weather, British soil, and the kit you can actually buy here.
    </p>
  </section>

  {articles.length > 0 ? (
    <section class="max-w-6xl mx-auto px-6 pb-24">
      <div class="flex items-baseline justify-between mb-10">
        <h2 class="font-serif text-3xl text-forest-800 tracking-tight">Latest</h2>
        <a href="/articles" class="text-sm text-terracotta-600 hover:text-terracotta-700">All articles →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-12">
        {featured && <ArticleCard article={featured} featured={true} />}
        {rest.map(article => <ArticleCard article={article} />)}
      </div>
    </section>
  ) : (
    <section class="max-w-2xl mx-auto px-6 pb-24 text-center">
      <p class="text-ink-500 italic font-serif text-lg">First articles coming soon.</p>
    </section>
  )}

  <section class="bg-forest-50 py-20 px-6 border-y border-forest-200/60">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-serif text-3xl md:text-4xl text-forest-900 mb-4 tracking-tight">
        The monthly lawn job list.
      </h2>
      <p class="text-ink-700 mb-8 leading-relaxed">
        One email a month telling you exactly what to do in your lawn this month. No spam, no nonsense, unsubscribe whenever.
      </p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="your@email.com"
          class="flex-1 px-4 py-3 rounded-md border border-forest-300 bg-cream-50 text-ink-900 placeholder:text-ink-300 focus:outline-none focus:ring-2 focus:ring-forest-400"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-forest-700 text-cream-50 rounded-md font-medium hover:bg-forest-800 transition-colors"
        >
          Subscribe
        </button>
      </form>
    </div>
  </section>
</BaseLayout>