---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleCard from '@components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = [
    { slug: 'lawn-care', label: 'Lawn Care', description: 'Mowing, feeding, watering — the routine that keeps a lawn alive.' },
    { slug: 'lawn-renovation', label: 'Lawn Renovation', description: 'Scarifying, aerating, overseeding, top-dressing — fixing what years of neglect did.' },
    { slug: 'product-reviews', label: 'Product Reviews', description: 'Honest reviews of UK lawn care kit. Tested, not theorised.' },
    { slug: 'seasonal', label: 'Seasonal Guides', description: 'What to do in your lawn this month. Tied to British weather, not American climate.' },
    { slug: 'problems-fixes', label: 'Problems & Fixes', description: 'Diagnose and fix the things that go wrong with British lawns.' },
  ];

  return categories.map(cat => ({
    params: { category: cat.slug },
    props: { categoryLabel: cat.label, categoryDescription: cat.description },
  }));
}

const { category } = Astro.params;
const { categoryLabel, categoryDescription } = Astro.props;

const articles = (await getCollection('articles', ({ data }) =>
  !data.draft && data.category === category
)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title={`${categoryLabel} | The Lawn Guide`}
  description={categoryDescription}
>
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-12">
    <p class="text-xs uppercase tracking-widest text-terracotta-600 font-medium mb-5">Category</p>
    <h1 class="font-serif text-4xl md:text-6xl text-forest-900 leading-tight tracking-tight mb-6">
      {categoryLabel}
    </h1>
    <p class="text-xl text-ink-500 font-serif italic leading-relaxed max-w-2xl">
      {categoryDescription}
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-24">
    {articles.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-12">
        {articles.map(article => <ArticleCard article={article} />)}
      </div>
    ) : (
      <p class="text-ink-500 italic font-serif">No articles in this category yet. Check back soon.</p>
    )}
  </section>
</BaseLayout>