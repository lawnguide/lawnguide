---
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, description, pubDate, category, heroImage } = article.data;

const categoryLabels: Record<string, string> = {
  'guides': 'Guides',
  'renovation': 'Renovation',
  'reviews': 'Reviews',
  'seasonal': 'Seasonal',
  'problems': 'Problems',
};

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<a href={`/${article.id.split('/').pop()}`} class="group block">
  <article class="h-full">
    {heroImage && (
      <div class="aspect-[4/3] overflow-hidden rounded-md mb-4 bg-forest-100">
        <img
          src={heroImage}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      </div>
    )}

    <div class="text-xs uppercase tracking-widest text-terracotta-600 font-medium mb-2">
      {categoryLabels[category]}
    </div>

    <h3 class="font-serif text-lg text-forest-800 leading-snug mb-2 group-hover:text-forest-900 transition-colors tracking-tight">
      {title}
    </h3>

    <time datetime={pubDate.toISOString()} class="text-xs text-ink-300 uppercase tracking-wider">
      {formattedDate}
    </time>
  </article>
</a>