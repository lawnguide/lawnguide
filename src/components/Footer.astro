---
const year = new Date().getFullYear();

const footerLinks = {
  Site: [
    { href: '/about', label: 'About' },
    { href: '/contact', label: 'Contact' },
    { href: '/newsletter', label: 'Newsletter' },
  ],
  Categories: [
    { href: '/category/lawn-care', label: 'Lawn Care' },
    { href: '/category/lawn-renovation', label: 'Renovation' },
    { href: '/category/product-reviews', label: 'Product Reviews' },
    { href: '/category/seasonal', label: 'Seasonal Guides' },
  ],
  Legal: [
    { href: '/affiliate-disclosure', label: 'Affiliate Disclosure' },
    { href: '/privacy', label: 'Privacy Policy' },
    { href: '/cookies', label: 'Cookie Policy' },
  ],
};
---

<footer class="border-t border-forest-200/60 bg-forest-800 text-cream-100 mt-24">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <div class="col-span-2 md:col-span-1">
        <h3 class="font-serif text-xl text-cream-50 mb-3">The Lawn Guide</h3>
        <p class="text-sm text-cream-200/80 leading-relaxed max-w-xs">
          Honest advice on UK lawn care, renovation, and the kit that actually works.
        </p>
      </div>

      {Object.entries(footerLinks).map(([title, links]) => (
        <div>
          <h4 class="font-sans font-medium text-sm uppercase tracking-wider text-cream-200/60 mb-4">
            {title}
          </h4>
          <ul class="space-y-2">
            {links.map(link => (
              <li>
                <a href={link.href} class="text-sm text-cream-100 hover:text-cream-50 transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="pt-8 border-t border-cream-100/10 flex flex-col md:flex-row justify-between gap-4 text-xs text-cream-200/60">
      <p>© {year} The Lawn Guide. All rights reserved.</p>
      <p>Made in the UK. Watered weekly.</p>
    </div>
  </div>
</footer>